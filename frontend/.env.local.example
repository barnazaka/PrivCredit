# PrivCredit Frontend — Environment Variables
# Copy this to .env.local and fill in deployed contract addresses

# Contract addresses (fill after deploying with hardhat)
NEXT_PUBLIC_PCT_ADDRESS=0xYourPrivCreditTokenAddressHere
NEXT_PUBLIC_POOL_ADDRESS=0xYourPrivCreditPoolAddressHere

# Chain (421614 = Arbitrum Sepolia)
NEXT_PUBLIC_CHAIN_ID=421614

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here
