# PrivCredit Contracts — Environment Variables
# Copy this to .env and fill in your values

# Your deployer wallet private key (WITHOUT 0x prefix is fine)
PRIVATE_KEY=your_private_key_here

# Arbitrum Sepolia RPC (default public endpoint is pre-filled in hardhat.config.ts)
# You can use Alchemy or Infura for more reliable RPC:
# Alchemy: https://dashboard.alchemy.com
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Arbiscan API key for contract verification (optional but recommended)
# Get one at: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_api_key_here
